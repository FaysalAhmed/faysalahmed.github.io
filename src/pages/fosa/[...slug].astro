---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const chapters = await getCollection('fosa');
  return chapters.filter(c => !c.data.draft).map(c => ({
    params: { slug: c.slug },
    props: { chapter: c },
  }));
}

const { chapter } = Astro.props;
const { Content } = await chapter.render();

const allChapters = (await getCollection('fosa'))
  .filter(c => !c.data.draft)
  .sort((a, b) => a.data.chapter - b.data.chapter);

const currentIdx = allChapters.findIndex(c => c.slug === chapter.slug);
const prev = currentIdx > 0 ? allChapters[currentIdx - 1] : null;
const next = currentIdx < allChapters.length - 1 ? allChapters[currentIdx + 1] : null;
const isToc = chapter.data.chapter === 0;
---

<BlogLayout title={chapter.data.title} description={chapter.data.description}>
  <nav class="breadcrumb">
    <a href="/fosa">Fundamentals of Solution Architecture</a>
    {!isToc && <span> / {chapter.data.title}</span>}
  </nav>

  <article class="chapter">
    {!isToc && (
      <header>
        <span class="chapter-num">Chapter {chapter.data.chapter}</span>
        <h1>{chapter.data.title}</h1>
      </header>
    )}
    <div class="content">
      <Content />
    </div>
  </article>

  <nav class="pagination">
    {prev ? (
      <a href={`/fosa/${prev.slug}/`} class="prev">
        <span class="dir">Previous</span>
        <span class="title">{prev.data.title}</span>
      </a>
    ) : <span />}
    {next && next.data.chapter > 0 && (
      <a href={`/fosa/${next.slug}/`} class="next">
        <span class="dir">Next</span>
        <span class="title">{next.data.title}</span>
      </a>
    )}
  </nav>
</BlogLayout>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 2rem;
  }
  .breadcrumb a { color: var(--muted); }
  .breadcrumb a:hover { color: var(--accent); }
  .chapter header {
    margin-bottom: 2rem;
  }
  .chapter-num {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--primary);
    font-weight: 600;
  }
  .chapter h1 {
    font-size: 2rem;
    line-height: 1.3;
    margin-top: 0.25rem;
  }
  .content {
    font-size: 1rem;
    line-height: 1.9;
  }
  .content h2 {
    font-size: 1.5rem;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--border);
  }
  .content h2:first-of-type { margin-top: 0; }
  .content h3 {
    font-size: 1.2rem;
    margin: 2rem 0 0.75rem;
    color: var(--text);
  }
  .content h4 {
    font-size: 1.05rem;
    margin: 1.5rem 0 0.5rem;
    color: var(--text);
  }
  .content p { margin-bottom: 1.25rem; }
  .content hr {
    margin: 2.5rem 0;
    border: none;
    border-top: 1px solid var(--border);
  }
  .content ul, .content ol { margin: 0 0 1.25rem 1.5rem; }
  .content li { margin-bottom: 0.4rem; }
  .content li > ul, .content li > ol { margin-bottom: 0; }
  .content blockquote {
    border-left: 4px solid var(--primary);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    color: var(--muted);
    background: rgba(15, 185, 162, 0.05);
    border-radius: 0 8px 8px 0;
  }
  .content blockquote p:last-child { margin-bottom: 0; }
  .content pre {
    margin: 1.5rem 0;
    border-radius: 8px;
    border: 1px solid var(--border);
  }
  .content code {
    font-size: 0.875em;
    background: rgba(2, 6, 23, 0.05);
    padding: 0.15em 0.35em;
    border-radius: 4px;
  }
  .content pre code {
    background: none;
    padding: 0;
  }
  .content table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 1.5rem 0;
    font-size: 0.9rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .content th, .content td {
    padding: 0.65rem 0.85rem;
    text-align: left;
  }
  .content thead th {
    background: linear-gradient(180deg, rgba(2, 6, 23, 0.04), rgba(2, 6, 23, 0.02));
    font-weight: 600;
    border-bottom: 2px solid var(--border);
  }
  .content tbody tr:not(:last-child) td {
    border-bottom: 1px solid var(--border);
  }
  .content tbody tr:nth-child(even) td {
    background: rgba(2, 6, 23, 0.02);
  }

  /* figures */
  .content figure {
    margin: 2rem 0;
    padding: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(2, 6, 23, 0.04);
  }
  .content figure figcaption {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--muted);
    text-align: center;
    font-style: italic;
  }
  .content figure :is(p, ul, ol, table, pre) { margin-bottom: 0; }
  .content figure table { margin: 0; }

  /* callout boxes */
  .content .callout {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    border-left: 4px solid;
  }
  .content .callout-tip {
    background: rgba(15, 185, 162, 0.07);
    border-color: var(--primary);
  }
  .content .callout-warn {
    background: rgba(234, 179, 8, 0.07);
    border-color: #eab308;
  }
  .content .callout-info {
    background: rgba(10, 132, 255, 0.07);
    border-color: var(--accent);
  }
  .content .callout strong:first-child {
    display: block;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.35rem;
  }
  .content .callout p:last-child { margin-bottom: 0; }

  /* definition lists */
  .content dl {
    margin: 1rem 0;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1rem;
  }
  .content dt {
    font-weight: 600;
    white-space: nowrap;
  }
  .content dd { margin: 0; color: var(--muted); }
  .pagination {
    display: flex;
    justify-content: space-between;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    gap: 1rem;
  }
  .pagination a {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    text-decoration: none;
    max-width: 50%;
  }
  .pagination a.next { align-items: flex-end; text-align: right; }
  .dir {
    font-size: 0.8rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .title {
    font-size: 0.95rem;
    color: var(--text);
    font-weight: 600;
  }
  .pagination a:hover .title { color: var(--accent); }
</style>
