---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const chapters = await getCollection('fosa');
  return chapters.filter(c => !c.data.draft).map(c => ({
    params: { slug: c.slug },
    props: { chapter: c },
  }));
}

const { chapter } = Astro.props;
const { Content } = await chapter.render();
const canonical = `${Astro.site}/fosa/${chapter.slug}/`;

const allChapters = (await getCollection('fosa'))
  .filter(c => !c.data.draft)
  .sort((a, b) => a.data.chapter - b.data.chapter);

const currentIdx = allChapters.findIndex(c => c.slug === chapter.slug);
const prev = currentIdx > 0 ? allChapters[currentIdx - 1] : null;
const next = currentIdx < allChapters.length - 1 ? allChapters[currentIdx + 1] : null;
const isToc = chapter.data.chapter === 0;
---

<BlogLayout title={chapter.data.title} description={chapter.data.description} canonical={canonical} isArticle={chapter.data.chapter > 0} article={{ headline: chapter.data.title, description: chapter.data.description, url: canonical }}>
  <div class="chapter-layout">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/fosa">Fundamentals of Solution Architecture</a>
      {!isToc && <span class="separator">/</span>}
      {!isToc && <span>{chapter.data.title}</span>}
    </nav>

    {!isToc ? (
      <header class="chapter-hero">
        <div class="chapter-hero__copy">
          <span class="chapter-kicker">Chapter {chapter.data.chapter}</span>
          <h1>{chapter.data.title}</h1>
          <p class="chapter-deck">{chapter.data.description}</p>
        </div>

        <aside class="chapter-hero__meta" aria-label="Chapter summary">
          <div class="meta-card">
            <span class="meta-label">Book</span>
            <strong>Fundamentals of Solution Architecture</strong>
          </div>
          <div class="meta-card">
            <span class="meta-label">Focus</span>
            <strong>Concepts, decisions, and practical architecture work</strong>
          </div>
        </aside>
      </header>
    ) : null}

    <article class="chapter">
      <div class="content">
        <Content />
      </div>
    </article>

    <nav class="pagination" aria-label="Chapter navigation">
      {prev ? (
        <a href={`/fosa/${prev.slug}/`} class="pagination-card prev">
          <span class="dir">Previous</span>
          <span class="title">{prev.data.title}</span>
        </a>
      ) : <span />}
      {next && next.data.chapter > 0 && (
        <a href={`/fosa/${next.slug}/`} class="pagination-card next">
          <span class="dir">Next</span>
          <span class="title">{next.data.title}</span>
        </a>
      )}
    </nav>
  </div>
</BlogLayout>

<style>
  .chapter-layout {
    display: grid;
    gap: 1.5rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
    letter-spacing: 0.01em;
  }
  .breadcrumb a {
    color: var(--muted);
    font-weight: 500;
  }
  .breadcrumb a:hover { color: var(--accent); }
  .separator { opacity: 0.5; }

  .chapter-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.8fr) minmax(260px, 0.9fr);
    gap: 1rem;
    align-items: stretch;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 18px;
    background:
      radial-gradient(circle at top left, rgba(15, 185, 162, 0.09), transparent 45%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(248, 250, 252, 0.96));
    box-shadow: 0 18px 50px rgba(15, 23, 36, 0.06);
  }

  .chapter-hero__copy {
    display: grid;
    align-content: start;
    gap: 0.75rem;
  }

  .chapter-kicker {
    width: fit-content;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--primary);
    font-weight: 700;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    background: rgba(15, 185, 162, 0.08);
  }

  .chapter-hero h1 {
    font-size: clamp(2rem, 4vw, 3.1rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .chapter-deck {
    max-width: 65ch;
    color: var(--muted);
    font-size: 1.03rem;
    line-height: 1.8;
    margin: 0;
  }

  .chapter-hero__meta {
    display: grid;
    gap: 0.75rem;
  }

  .meta-card {
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.92);
  }

  .meta-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .meta-card strong {
    color: var(--text);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .chapter {
    display: grid;
    gap: 1rem;
  }

  .content {
    font-size: 1.03rem;
    line-height: 1.95;
    color: var(--text);
  }
  .content h2 {
    font-size: 1.55rem;
    margin: 2.75rem 0 1rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--border);
    letter-spacing: -0.02em;
  }
  .content h2:first-of-type { margin-top: 0; }
  .content h3 {
    font-size: 1.22rem;
    margin: 2rem 0 0.75rem;
    color: var(--text);
  }
  .content h4 {
    font-size: 1.05rem;
    margin: 1.5rem 0 0.5rem;
    color: var(--text);
  }
  .content p { margin-bottom: 1.25rem; }
  .content > p:first-of-type {
    font-size: 1.08rem;
    color: var(--muted);
  }
  .content hr {
    margin: 2.5rem 0;
    border: none;
    border-top: 1px solid var(--border);
  }
  .content ul, .content ol { margin: 0 0 1.25rem 1.5rem; }
  .content li { margin-bottom: 0.4rem; }
  .content li > ul, .content li > ol { margin-bottom: 0; }
  .content blockquote {
    border-left: 4px solid var(--primary);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    color: var(--muted);
    background: rgba(15, 185, 162, 0.05);
    border-radius: 0 8px 8px 0;
  }
  .content blockquote p:last-child { margin-bottom: 0; }
  .content pre {
    margin: 1.5rem 0;
    border-radius: 14px;
    border: 1px solid rgba(15, 23, 36, 0.08);
    background: #0f1724;
    box-shadow: 0 14px 36px rgba(15, 23, 36, 0.12);
  }
  .content code {
    font-size: 0.875em;
    background: rgba(15, 23, 36, 0.06);
    padding: 0.16em 0.4em;
    border-radius: 6px;
  }
  .content pre code {
    background: none;
    padding: 0;
  }
  .content table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 1.5rem 0;
    font-size: 0.9rem;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(15, 23, 36, 0.08);
    background: var(--surface);
    box-shadow: 0 10px 24px rgba(15, 23, 36, 0.04);
  }
  .content th, .content td {
    padding: 0.8rem 0.95rem;
    text-align: left;
  }
  .content thead th {
    background: linear-gradient(180deg, rgba(15, 23, 36, 0.05), rgba(15, 23, 36, 0.02));
    font-weight: 600;
    border-bottom: 1px solid rgba(15, 23, 36, 0.08);
  }
  .content tbody tr:not(:last-child) td {
    border-bottom: 1px solid var(--border);
  }
  .content tbody tr:nth-child(even) td {
    background: rgba(15, 23, 36, 0.018);
  }

  /* figures */
  .content figure {
    margin: 2.25rem 0;
    padding: 1.25rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,250,252,0.98));
    border: 1px solid rgba(15, 23, 36, 0.08);
    border-radius: 16px;
    box-shadow: 0 16px 36px rgba(15, 23, 36, 0.05);
  }
  .content figure figcaption {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--muted);
    text-align: center;
    font-style: italic;
  }
  .content figure :is(p, ul, ol, table, pre) { margin-bottom: 0; }
  .content figure table { margin: 0; }

  /* callout boxes */
  .content .callout {
    margin: 1.75rem 0;
    padding: 1.05rem 1.25rem;
    border-radius: 14px;
    border-left: 4px solid;
    box-shadow: 0 8px 20px rgba(15, 23, 36, 0.04);
  }
  .content .callout-tip {
    background: rgba(15, 185, 162, 0.07);
    border-color: var(--primary);
  }
  .content .callout-warn {
    background: rgba(234, 179, 8, 0.07);
    border-color: #eab308;
  }
  .content .callout-info {
    background: rgba(10, 132, 255, 0.07);
    border-color: var(--accent);
  }
  .content .callout strong:first-child {
    display: block;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.35rem;
  }
  .content .callout p:last-child { margin-bottom: 0; }

  /* definition lists */
  .content dl {
    margin: 1rem 0;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1rem;
  }
  .content dt {
    font-weight: 600;
    white-space: nowrap;
  }
  .content dd { margin: 0; color: var(--muted); }
  .pagination {
    display: flex;
    justify-content: space-between;
    margin-top: 1rem;
    gap: 1rem;
  }
  .pagination-card {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-decoration: none;
    width: min(100%, 280px);
    padding: 1rem 1.1rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 8px 20px rgba(15, 23, 36, 0.04);
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .pagination-card:hover {
    transform: translateY(-2px);
    border-color: rgba(15, 185, 162, 0.28);
    box-shadow: 0 14px 28px rgba(15, 23, 36, 0.08);
  }
  .pagination a.next { align-items: flex-end; text-align: right; margin-left: auto; }
  .dir {
    font-size: 0.8rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .title {
    font-size: 0.95rem;
    color: var(--text);
    font-weight: 600;
    line-height: 1.4;
  }
  .pagination a:hover .title { color: var(--accent); }

  @media (max-width: 860px) {
    .chapter-hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .content {
      font-size: 1rem;
      line-height: 1.85;
    }
    .chapter-hero {
      padding: 1.15rem;
      border-radius: 16px;
    }
    .chapter-hero h1 {
      font-size: 1.9rem;
    }
    .pagination {
      flex-direction: column;
    }
    .pagination-card,
    .pagination a.next {
      width: 100%;
      max-width: none;
      align-items: flex-start;
      text-align: left;
      margin-left: 0;
    }
  }
</style>
